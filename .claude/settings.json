{
  "mcpServers": {
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    },
    "atlassian": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.atlassian.com/v1/sse"]
    },
    "reltio-on-reltio": {
      "type": "stdio",
      "command": "bash",
      "args": [
        "./reltio-ondemand-ops-agent-69ddb50d80dc/scripts/start-reltio-mcp.sh"
      ],
      "env": {
        "RELTIO_MCP_ENVIRONMENT": "${RELTIO_MCP_ENVIRONMENT}",
        "RELTIO_MCP_TENANT_ID": "${RELTIO_MCP_TENANT_ID}",
        "RELTIO_CLIENT_ID": "${RELTIO_CLIENT_ID}",
        "RELTIO_CLIENT_SECRET": "${RELTIO_CLIENT_SECRET}",
        "RELTIO_AUTH_TENANT_ID": "${RELTIO_AUTH_TENANT_ID}"
      }
    },
    "bitbucket": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "bitbucket-mcp@latest"],
      "env": {
        "BITBUCKET_URL": "https://api.bitbucket.org/2.0",
        "BITBUCKET_WORKSPACE": "reltio-ondemand",
        "BITBUCKET_USERNAME": "${BITBUCKET_USERNAME}",
        "BITBUCKET_PASSWORD": "${BITBUCKET_APP_PASSWORD}"
      }
    }
  }
}
